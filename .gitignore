.env

config/.cache/
config/.cline/
config/.local/
config/.ssh/

config/extensions/
!config/extensions/.gitkeep

config/workspace/
!config/workspace/.gitkeep

config/data/*
!config/data/User/
config/data/User/*
!config/data/User/settings.json

repos/*
!repos/.gitkeep

vsix/*
!vsix/.gitkeep

users/*/repos/*
!users/*/repos/.gitkeep

users/*/config/data/*
!users/*/config/data/User/
users/*/config/data/User/*
!users/*/config/data/User/settings.json

users/*/config/extensions/
users/*/config/.cache/
users/*/config/.cline/
users/*/config/.local/
users/*/config/.ssh/
users/*/config/workspace/
